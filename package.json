{
  "name": "warpdesk-workspace-duck-island-icecream",
  "private": true,
  "description": "Local npm scripts for WarpDesk ticket CLI (no publish)",
  "scripts": {
    "warpdesk:tickets": "node vendor/warpdesk-client-kit/mcp/tickets-cli.mjs list",
    "warpdesk:tickets:queue": "node vendor/warpdesk-client-kit/mcp/tickets-cli.mjs list --queue",
    "warpdesk:ticket": "node vendor/warpdesk-client-kit/mcp/tickets-cli.mjs get",
    "warpdesk:tickets:lookup": "node vendor/warpdesk-client-kit/mcp/tickets-cli.mjs lookup",
    "warpdesk:ticket:patch": "node vendor/warpdesk-client-kit/mcp/tickets-cli.mjs patch",
    "warpdesk:ticket:draft": "node vendor/warpdesk-client-kit/mcp/tickets-cli.mjs draft"
  }
}
