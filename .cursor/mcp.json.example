{
  "mcpServers": {
    "edf-tickets": {
      "command": "npm",
      "args": [
        "run",
        "mcp:tickets"
      ],
      "cwd": "../vendor/edf-client-kit",
      "env": {
        "EDF_BASE_URL": "https://extreme-development-framework.vercel.app",
        "EDF_SUPABASE_ACCESS_TOKEN": ""
      }
    }
  }
}
