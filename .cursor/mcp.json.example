{
  "mcpServers": {
    "warpdesk-tickets": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/vendor/warpdesk-client-kit/node_modules/tsx/dist/cli.mjs",
        "${workspaceFolder}/vendor/warpdesk-client-kit/mcp/src/index.ts"
      ],
      "cwd": "${workspaceFolder}/vendor/warpdesk-client-kit",
      "env": {
        "WARPDESK_BASE_URL": "https://warpdesk.vercel.app",
        "WARPDESK_PERSONAL_ACCESS_TOKEN": ""
      }
    }
  }
}
