{
  "mcpServers": {
    "edf-tickets": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/vendor/edf-client-kit/node_modules/tsx/dist/cli.mjs",
        "${workspaceFolder}/vendor/edf-client-kit/mcp/src/index.ts"
      ],
      "cwd": "${workspaceFolder}/vendor/edf-client-kit",
      "env": {
        "EDF_BASE_URL": "https://extreme-development-framework.vercel.app",
        "EDF_PERSONAL_ACCESS_TOKEN": ""
      }
    }
  }
}
